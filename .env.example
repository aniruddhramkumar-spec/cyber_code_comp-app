# ChartVault Configuration
# Copy this file to .env and fill in your values

# Encryption Key (auto-generated if not provided)
# ENCRYPTION_KEY=your-encryption-key-here

# Database Configuration
DB_FILE=.data/graphs.db

# Security Settings
MAX_LOGIN_ATTEMPTS=5
SESSION_TIMEOUT=3600

# Email Configuration for MFA (Required for email-based MFA)
# For Gmail: Use your Gmail address and an App Password (not your regular password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com
EMAIL_USE_TLS=true

# Streamlit Configuration
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_SERVER_RUNONCEHOOKS=false
